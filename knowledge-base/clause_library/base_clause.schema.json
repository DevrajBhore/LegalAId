{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": [
    "clause_id",
    "name",
    "category",
    "document_types",
    "jurisdiction",
    "text",
    "legal_basis",
    "mandatory",
    "enforceability",
    "risk_level",
    "invalid_if",
    "source",
    "version"
  ],
  "properties": {
    "clause_id": { "type": "string" },
    "name": { "type": "string" },
    "category": { "type": "string" },
    "document_types": {
      "type": "array",
      "items": { "type": "string" }
    },
    "jurisdiction": { "type": "string" },
    "text": { "type": "string" },
    "legal_basis": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "act": { "type": "string" },
          "section": { "type": "string" },
          "article": { "type": "string" },
          "note": { "type": "string" }
        },
        "required": ["act"],
        "anyOf": [
          { "required": ["section"] },
          { "required": ["article"] }
        ]
      }
    },
    "mandatory": { "type": "boolean" },
    "enforceability": {
      "type": "string",
      "enum": ["HIGH", "MEDIUM", "LOW"]
    },
    "risk_level": {
      "type": "string",
      "enum": ["LOW", "MEDIUM", "HIGH"]
    },
    "invalid_if": {
      "type": "array",
      "items": { "type": "string" }
    },
    "source": { "type": "string" },
    "version": { "type": "string" }
  }
}
